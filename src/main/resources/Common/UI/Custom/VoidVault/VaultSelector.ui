$Common = "../Common.ui";

@PrimaryButtonStyle = TextButtonStyle(
  Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #E8FFE8), Background: #1A3A24(0.98)),
  Hovered: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #FFFFFF), Background: #285C38(0.98)),
  Pressed: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #FFFFFF), Background: #347448(0.98)),
  Disabled: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #7F9184), Background: #17251B(0.80))
);

@SecondaryButtonStyle = TextButtonStyle(
  Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #EEDCFF), Background: #251036(0.98)),
  Hovered: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #FFFFFF), Background: #462066(0.98)),
  Pressed: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #FFFFFF), Background: #6E35A0(0.98)),
  Disabled: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #796B86), Background: #17101E(0.80))
);

@AccentButtonStyle = TextButtonStyle(
  Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #FFE4FF), Background: #3A1A3A(0.98)),
  Hovered: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #FFFFFF), Background: #5A2A5A(0.98)),
  Pressed: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #FFFFFF), Background: #7A3A7A(0.98)),
  Disabled: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #7C697C), Background: #211421(0.80))
);

@CloseButtonStyle = TextButtonStyle(
  Default: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #F1E5FF), Background: #2F1644(0.98)),
  Hovered: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #FFFFFF), Background: #572779(0.98)),
  Pressed: (LabelStyle: (HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true, FontSize: 13, TextColor: #FFFFFF), Background: #7538A5(0.98))
);

Group {
  LayoutMode: Center;
  Background: #000000(0.48);
  Group #Panel {
    Background: #0B0612(0.98); OutlineColor: #7A39B4(0.60); OutlineSize: 1;
    Anchor: (Width: 860, Height: 850); Padding: (Top: 20, Bottom: 20, Left: 28, Right: 28); LayoutMode: Top;
    Group #HeaderGlow { Anchor: (Height: 3, Bottom: 12); Background: #A550E4(0.88); }
    Label #Title { Style: (FontSize: 32, RenderBold: true, HorizontalAlignment: Center, TextColor: #E7B2FF); Anchor: (Height: 42); Text: "Void Vault"; }
    Label #Subtitle { Style: (FontSize: 15, HorizontalAlignment: Center, TextColor: #DCD1EA); Anchor: (Height: 24, Top: 2, Bottom: 10); Text: "Choose which vault you want to open"; }
    Group #CardArea { Background: #170A24(0.92); OutlineColor: #8C44CC(0.32); OutlineSize: 1; Anchor: (Height: 580, Bottom: 14); Padding: (Top: 8, Bottom: 8, Left: 8, Right: 8); LayoutMode: Top;
      Group #CardRow0 { LayoutMode: Left; Anchor: (Height: 180, Bottom: 8);
        Group #Card0 {
          Background: #1E0E30(0.96); OutlineColor: #7A39B4(0.42); OutlineSize: 1;
          Anchor: (Width: 380, Height: 178, Right: 12);
          Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12); LayoutMode: Top;
          Group #CardAccent0 { Anchor: (Height: 3, Bottom: 8); Background: #7A39B4; }
          Group #CardHeader0 { LayoutMode: Left; Anchor: (Height: 40, Bottom: 7);
            Group #CardIconBadge0 { Background: #2A123F; OutlineColor: #9A59D4(0.55); OutlineSize: 1; Anchor: (Width: 48, Height: 40, Right: 9); LayoutMode: Center;
              ItemIcon #CardIcon0 { Anchor: (Width: 38, Height: 34); ItemId: "VoidVault"; ShowItemTooltip: false; HitTestVisible: false; }
              Label #CardIconFallback0 { Style: (FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #FFFFFF); Anchor: (Width: 38, Height: 34); Text: "VV"; Visible: false; }
            }
            Group #CardTitleArea0 { LayoutMode: Top; Anchor: (Width: 194, Height: 40, Right: 5);
              Label #CardName0 { Style: (FontSize: 15, RenderBold: true, TextColor: #F0D8FF); Anchor: (Height: 22); Text: "Vault"; }
              Label #CardNumber0 { Style: (FontSize: 11, TextColor: #A58BB9); Anchor: (Height: 16); Text: "Vault 1"; }
            }
            Label #CardDefaultBadge0 { Style: (FontSize: 9, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #FFD66B); Background: #3A2D12(0.88); Anchor: (Width: 58, Height: 20, Right: 3); Text: "DEFAULT"; Visible: false; }
            Label #CardFavoriteBadge0 { Style: (FontSize: 17, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #FFD66B); Anchor: (Width: 20, Height: 20); Text: "*"; Visible: false; }
          }
          Group #CardUpperSpacer0 { FlexWeight: 1; }
          Label #CardOccupancy0 { Style: (FontSize: 12, TextColor: #C9B4D9); Anchor: (Height: 16, Bottom: 7); Text: "0 / 9 slots"; }
          ProgressBar #CardProgressBar0 { Anchor: (Height: 8, Bottom: 8); Background: #160A22; Bar: #7A39B4; Value: 0; }
          Label #CardOverflowBadge0 { Style: (FontSize: 10, RenderBold: true, TextColor: #FF8095); Anchor: (Height: 14); Text: ""; Visible: false; }
          Group #CardLowerSpacer0 { FlexWeight: 1; }
          Group #CardActions0 { LayoutMode: Left; Anchor: (Height: 34);
            TextButton #CardOpen0 { Style: @PrimaryButtonStyle; Anchor: (Width: 166, Height: 34, Right: 10); Text: "Open"; }
            TextButton #CardManage0 { Style: @SecondaryButtonStyle; Anchor: (Width: 166, Height: 34); Text: "Manage"; }
          }
        }
